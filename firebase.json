{
  "functions": {
    "source": "functions",
    "codebase": "default",
    "ignore": ["node_modules", ".git"]
  },
  "hosting": {
    "site": "apodcastgeek-website",
    "public": ".",
    "ignore": ["firebase.json", ".firebase", "functions/**", "node_modules/**", ".git/**", ".github/**", "scripts/**", ".gitignore", ".firebaserc"],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [{"key": "Cache-Control", "value": "no-cache"}]
      },
      {
        "source": "**/*.png",
        "headers": [{"key": "Cache-Control", "value": "max-age=31536000"}]
      }
    ]
  }
}
